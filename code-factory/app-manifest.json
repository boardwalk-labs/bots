{
  "name": "boardwalk-code-factory",
  "url": "https://github.com/boardwalk-labs/bots/tree/main/code-factory",
  "public": false,
  "default_permissions": {
    "contents": "write",
    "pull_requests": "write",
    "issues": "write",
    "metadata": "read"
