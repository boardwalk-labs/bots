# Copy to .env in each deployable package (orchestrator/, build/) for `boardwalk dev`, which reads
# both env variables and secrets from this file.
#
# On hosted Boardwalk these go in the ORG BASE environment, because webhook-triggered runs (the
# github-dispatcher -> code-factory chain) always run in the base; a named environment only applies
# to manual `run --environment <name>` or scheduled runs. Omit --environment to target the base:
#   - GITHUB_APP_ID is a NON-SECRET variable:  boardwalk variables set GITHUB_APP_ID <id>
#   - GITHUB_APP_PRIVATE_KEY is a SECRET:      boardwalk secrets set GITHUB_APP_PRIVATE_KEY
# Only the build + orchestrator packages need these; plan and review use no credentials.

# The App's numeric ID (App settings -> "App ID"). Read from the environment as process.env.GITHUB_APP_ID.
GITHUB_APP_ID=123456

# The App's private key (the .pem from "Generate a private key"). For a .env file put it on one line
# with literal \n between the lines; the code un-escapes them. On hosted Boardwalk paste the real
# multi-line PEM into the secret value.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
