# Copy to .env in each deployable package (orchestrator/, build/) for `boardwalk dev`. On hosted
# Boardwalk, add these as org secrets in the dashboard instead.
#
# These come from the GitHub App you create (see README, "Set up the GitHub App"). The orchestrator
# and build packages both declare them in permissions.secrets; plan and review need no secrets.

# The App's numeric ID (App settings -> "App ID").
GITHUB_APP_ID=123456

# The App's private key (the .pem you download from "Generate a private key"). For a .env file put it
# on one line with literal \n between the lines; the code un-escapes them. On hosted Boardwalk paste
# the real multi-line PEM into the secret field.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
